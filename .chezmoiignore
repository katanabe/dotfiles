# APM-managed paths — chezmoi must not deploy these.
# apm install (re)creates them, lockfile pins versions for reproducibility.
.apm/apm_modules

# Treat ~/.claude/skills/* as agent-managed territory by default.
# APM uses ~/.agents/skills; re-include only the personal chezmoi-managed copies below.
.claude/skills/*
!.claude/skills/chezmoi-management
!.claude/skills/chezmoi-management/**
# herdr: vendored snapshot of upstream SKILL.md (not APM-packaged). Refreshed via /update-skills.
!.claude/skills/herdr
!.claude/skills/herdr/**
