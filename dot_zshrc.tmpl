# === Core ===
eval "$(/opt/homebrew/bin/brew shellenv)"
eval "$(mise activate zsh)"
eval "$(sheldon source)"
eval "$(direnv hook zsh)"

# === Environment ===
export TERM=xterm-256color
export ANDROID_HOME=$HOME/Library/Android/sdk
export PATH=$PATH:$ANDROID_HOME/emulator
export PATH=$PATH:$ANDROID_HOME/platform-tools
export PATH=$PATH:$ANDROID_HOME/cmdline-tools/latest/bin
export PATH="/opt/homebrew/opt/openjdk@21/bin:$PATH"
export PATH=$PATH:$HOME/.maestro/bin
export PATH="$HOME/.local/bin:$PATH"

# fzf: use fd as candidate source and standardize appearance
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --exclude .git'
export FZF_DEFAULT_OPTS='--height 60% --layout=reverse --border --preview-window=right:60%:wrap --bind ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up'

# === Functions ===
apm-add() {
  local pkg="$1"; local name="${pkg##*/}"
  apm install -g "$pkg" || return 1
  chezmoi re-add ~/.apm/apm.yml ~/.apm/apm.lock.yaml
  # No .chezmoiignore append: the wildcard `.claude/skills/*` rule already
  # covers any APM-deployed skill (see chezmoi-management skill for the boundary).
  echo "added: $name (commit/push the dotfiles repo to persist)"
}

zj() {
  if git rev-parse --git-dir > /dev/null 2>&1; then
    zellij --layout dev
  else
    zellij
  fi
}

# === Local overrides (machine-specific, not tracked) ===
[ -f ~/.zshrc.local ] && source ~/.zshrc.local
